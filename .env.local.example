# FlowRoll — local environment
# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Supabase dashboard → Project settings → API.
#
# These two are PUBLIC (they ship to the browser). The anon key is safe to expose
# because RLS gates everything. Never put the service_role key in this file.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Where the magic-link should send users after they click the email link.
# Locally this is your dev server; in prod it'll be your Vercel URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
