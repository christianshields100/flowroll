# FlowRoll — local environment
# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Supabase dashboard → Project settings → API.
#
# These two are PUBLIC (they ship to the browser). The anon key is safe to expose
# because RLS gates everything. Never put the service_role key in this file.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Where the magic-link should send users after they click the email link.
# Locally this is your dev server; in prod it'll be your Vercel URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SERVER-ONLY (no NEXT_PUBLIC_ prefix — never ships to the browser).
# Powers the Coach chatbot. Get one at https://platform.claude.com/
ANTHROPIC_API_KEY=sk-ant-...

# SERVER-ONLY. Optional — powers the gym autocomplete (Google Places). Without
# it, the gym field falls back to free-text entry. To enable: in Google Cloud
# create/select a project, enable "Places API (New)", create an API key, and
# (recommended) restrict it to the Places API.
GOOGLE_PLACES_API_KEY=
